{
  "name": "@easymindmap/emm-parser",
  "version": "0.1.0",
  "description": "EasyMindMap Markdown (EMM) reference parser/serializer — Markdown ↔ mindmap JSON with lossless metadata layer",
  "license": "Apache-2.0",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "test": "tsx conformance/run.ts",
    "test:update": "tsx conformance/run.ts --update",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["mindmap", "markdown", "emm", "easymindmap", "parser"],
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
}
